# ═══════════════════════════════════════════════════════════════════
#  AI Chatbot — Environment Variables
#  Copy this file to .env and fill in your values.
#  On Vercel: set these in Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════════


# ── AI Provider ─────────────────────────────────────────────────────
# Choose: "openai" | "groq" | "demo"
# groq  = FREE, fast (recommended for new clients)
# openai = Paid, high quality (for premium clients)
# demo  = No API key needed (for testing / sales demos)
AI_PROVIDER=groq


# ── API Keys ─────────────────────────────────────────────────────────
# Only set the key for the provider you chose above.
# Groq is FREE — sign up at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk-your-groq-key-here

# OpenAI — https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the default AI model
# Groq options: llama-3.1-8b-instant (fast/free), llama-3.3-70b-versatile (smarter)
# OpenAI options: gpt-4o-mini (default), gpt-4o (premium)
# AI_MODEL=llama-3.3-70b-versatile


# ── Bot Personality (SYSTEM_PROMPT) ──────────────────────────────────
# This is the most important variable — it defines how the bot behaves.
# Change this for every client. Examples below:

# Generic assistant (default):
SYSTEM_PROMPT="You are a helpful customer support assistant. Be friendly, concise, and professional. Answer questions clearly and offer to help further."

# ── RESTAURANT example ──────────────────────────────────────────────
# SYSTEM_PROMPT="You are a friendly assistant for Bella Italia restaurant in Tbilisi. \
# Answer ONLY questions related to our restaurant. \
# \
# RESTAURANT INFO: \
# - Address: Rustaveli Ave 15, Tbilisi \
# - Phone: +995 599 123 456 \
# - Hours: Mon–Sun 12:00–23:00 \
# - Reservations: call us or use our website \
# \
# MENU HIGHLIGHTS: \
# - Margherita pizza: ₾18 \
# - Pasta Carbonara: ₾22 \
# - Grilled Salmon: ₾35 \
# - House wine (glass): ₾12 \
# - Today's special: ask our staff \
# \
# POLICIES: \
# - Free delivery on orders over ₾50 (within 5km) \
# - Delivery time: 30–45 minutes \
# - Vegetarian and gluten-free options available \
# - Groups over 8 people need reservation 24h in advance \
# \
# Always be warm and welcoming. If asked something you don't know (e.g. today's specials), \
# say 'Please call us at +995 599 123 456 for the latest info.' \
# Respond in the same language the customer uses (Georgian or English)."

# ── E-COMMERCE / SHOP example ───────────────────────────────────────
# SYSTEM_PROMPT="You are a sales assistant for StyleHub online clothing store. \
# Help customers find products, answer sizing questions, and explain our return policy. \
# Return policy: 30-day free returns. Shipping: free over $50. \
# Always end with a helpful suggestion to browse our new arrivals."

# ── HOTEL / B&B example ─────────────────────────────────────────────
# SYSTEM_PROMPT="You are a concierge assistant for Old Town Hotel Tbilisi. \
# Help guests with: room availability, amenities, local attractions, and check-in info. \
# Check-in: 14:00. Check-out: 12:00. Free WiFi. Breakfast included. \
# Address: Shardeni St 8. Phone: +995 322 987 654."


# ── Branding (visible in the chat UI) ────────────────────────────────
# These appear in the chatbot interface. Customize for each client.
# All NEXT_PUBLIC_ variables are safe to expose to the browser.

# Bot name shown in the header
NEXT_PUBLIC_CHAT_TITLE=AI Assistant

# Optional tagline shown under the bot name (leave empty for "Online")
NEXT_PUBLIC_CHAT_SUBTITLE=

# Empty state welcome screen
NEXT_PUBLIC_WELCOME_HEADING=How can I help you today?
NEXT_PUBLIC_WELCOME_BODY=Ask me anything about our menu, hours, or reservations!

# Suggested prompt buttons (JSON array — must be valid JSON)
NEXT_PUBLIC_PROMPTS=["What's on the menu?","Do you take reservations?","What are your opening hours?","Do you offer delivery?"]


# ── Security ──────────────────────────────────────────────────────────
# Optional: restrict which domains can call your API
# Leave empty to allow all origins (fine for single-client deployments)
# ALLOWED_ORIGIN=https://client-website.com
