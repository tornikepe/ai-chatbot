# ═══════════════════════════════════════════════════════════════════
#  Georgian Bot — Environment Variables
#  Copy this file to .env and fill in your real values.
#  On Vercel: Project → Settings → Environment Variables
#  NEVER commit the real .env file to git.
# ═══════════════════════════════════════════════════════════════════


# ─── AI Provider ────────────────────────────────────────────────────
# Choose: "openai" | "groq" | "demo"
AI_PROVIDER=groq

# Groq — FREE, very fast. Sign up at https://console.groq.com (no credit card)
GROQ_API_KEY=gsk-your-groq-key-here

# OpenAI (paid, highest quality)
# OPENAI_API_KEY=sk-your-openai-key-here

# Optional: override the default model.
# Groq: llama-3.3-70b-versatile (smart, default) | llama-3.1-8b-instant (fastest)
# OpenAI: gpt-4o-mini (default) | gpt-4o (premium)
# AI_MODEL=llama-3.3-70b-versatile


# ─── Bot Personality (most important variable) ──────────────────────
# Defines exactly how the bot speaks. Rewrite this for each client.
# The default makes the bot speak Georgian / English / Russian fluently.

# SYSTEM_PROMPT="You are the AI assistant for [BUSINESS NAME], a [TYPE] based in [CITY]. \
# BUSINESS INFO: \
# - Address: ... \
# - Phone: +995 ... \
# - Hours: ... \
# TONE: warm, professional, concise. \
# Always reply in the same language the user wrote in (Georgian / English / Russian). \
# Never invent prices or stock. If you don't know, say so and collect the user's name + phone so the team can follow up."


# ─── Landing page behavior ─────────────────────────────────────────
# Set to "true" to hide the landing page and show only the chat (for iframe embeds).
# NEXT_PUBLIC_HIDE_LANDING=false


# ─── Your contact details (shown in the Contact section) ───────────
NEXT_PUBLIC_CONTACT_EMAIL=peitrishvilitornike@gmail.com
NEXT_PUBLIC_CONTACT_LINKEDIN=linkedin.com/in/tornike-peitrishvili



# ─── Security (optional) ──────────────────────────────────────────
# Restrict which domain can call your API. Leave empty to allow all.
# ALLOWED_ORIGIN=https://client-website.com
