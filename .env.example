# ─────────────────────────────────────────────────────────────
# AI Provider — choose one: "openai", "groq", or "demo"
# ─────────────────────────────────────────────────────────────
#
# openai  — Paid, high quality. Requires credit balance at platform.openai.com
# groq    — FREE, very fast. Sign up at console.groq.com (no credit card needed)
# demo    — No API key, returns canned responses. Good for testing the UI.
#
AI_PROVIDER=groq

# Optional: override the default model for your provider
# OpenAI: "gpt-4o-mini" (default), "gpt-4o", "gpt-3.5-turbo"
# Groq:   "llama-3.1-8b-instant" (default), "llama-3.3-70b-versatile", "mixtral-8x7b-32768"
# AI_MODEL=llama-3.1-8b-instant

# ─────────────────────────────────────────────────────────────
# API Keys — only the key matching your AI_PROVIDER is required
# ─────────────────────────────────────────────────────────────

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Groq — get from https://console.groq.com/keys (free)
GROQ_API_KEY=gsk-your-groq-key-here

# ─────────────────────────────────────────────────────────────
# Customize the chatbot's personality
# ─────────────────────────────────────────────────────────────
SYSTEM_PROMPT="You are a helpful customer support assistant. Be friendly, concise, and professional."
